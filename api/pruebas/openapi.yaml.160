openapi: 3.0.0
info:
  title: AgriAPI
  description: API para gestión agrícola
  version: 1.0.0
servers:
  - url: http://192.168.1.224
    description: Servidor local de desarrollo
  - url: https://api.bueso.duckdns.org
    description: Servidor de producción

tags:
  - name: Autenticación
    description: Operaciones de login y generación de tokens
  - name: Gastos
    description: Gestión de gastos agrícolas
  - name: Albaranes
    description: Gestión de albaranes (cabecera y detalles)
  - name: Archivos
    description: Subida y descarga de archivos
  - name: Fincas
    description: Gestión de fincas agrícolas

paths:
  /api/login:
    post:
      tags: [Autenticación]
      summary: Autenticación de usuario
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                email:
                  type: string
                  example: usuario@ejemplo.com
                password:
                  type: string
                  example: contraseña123
              required: [email, password]
      responses:
        '200':
          description: Autenticación exitosa
          content:
            application/json:
              schema:
                type: object
                properties:
                  token:
                    type: string
                    description: JWT para autenticación
        '400':
          description: Faltan credenciales
        '401':
          description: Credenciales incorrectas

  /api/gastos:
    get:
      tags: [Gastos]
      summary: Obtener todos los gastos del agricultor
      security:
        - bearerAuth: []
      responses:
        '200':
          description: Lista de gastos
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/Gasto'
    post:
      tags: [Gastos]
      summary: Crear un nuevo gasto
      security:
        - bearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/GastoInput'
      responses:
        '200':
          description: Gasto creado exitosamente
        '400':
          description: Faltan datos requeridos

  /api/albarancabecera:
    post:
      tags: [Albaranes]
      summary: Crear cabecera de albarán
      security:
        - bearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/AlbaranCabeceraInput'
      responses:
        '200':
          description: Cabecera de albarán creada
          content:
            application/json:
              schema:
                type: object
                properties:
                  mensaje:
                    type: string
                  kalbaran:
                    type: string
                  nuevoid:
                    type: integer

  /api/albarandetalles:
    post:
      tags: [Albaranes]
      summary: Añadir detalle a albarán
      security:
        - bearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/AlbaranDetalleInput'
      responses:
        '201':
          description: Detalle de albarán creado
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AlbaranDetalle'

  /api/albarandetalles/{kalbaran}:
    get:
      tags: [Albaranes]
      summary: Obtener detalles de un albarán
      security:
        - bearerAuth: []
      parameters:
        - name: kalbaran
          in: path
          required: true
          schema:
            type: string
      responses:
        '200':
          description: Lista de detalles del albarán
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/AlbaranDetalle'
        '404':
          description: Albarán no encontrado

  /api/archivo:
    post:
      tags: [Archivos]
      summary: Subir un archivo
      security:
        - bearerAuth: []
      requestBody:
        required: true
        content:
          multipart/form-data:
            schema:
              type: object
              properties:
                archivo:
                  type: string
                  format: binary
                kuuid:
                  type: string
                tipo:
                  type: string
      responses:
        '200':
          description: Archivo subido correctamente
          content:
            application/json:
              schema:
                type: object
                properties:
                  mensaje:
                    type: string
                  uuid:
                    type: string
        '400':
          description: Faltan parámetros o archivo

  /api/gastos/descargararchivo/{id}:
    get:
      tags: [Archivos]
      summary: Descargar archivo por ID (desde BBDD)
      security:
        - bearerAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      responses:
        '200':
          description: Archivo descargado
          content:
            application/octet-stream:
              schema:
                type: string
                format: binary
        '404':
          description: Archivo no encontrado

  /api/gastos/descargararchivonas/{id}:
    get:
      tags: [Archivos]
      summary: Descargar archivo por ID (desde NAS)
      security:
        - bearerAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      responses:
        '200':
          description: Archivo descargado
          content:
            application/octet-stream:
              schema:
                type: string
                format: binary
        '403':
          description: Ruta no permitida
        '404':
          description: Archivo no encontrado

  /api/crearfinca:
    post:
      tags: [Fincas]
      summary: Crear una nueva finca
      security:
        - bearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/FincaInput'
      responses:
        '200':
          description: Finca creada exitosamente
          content:
            application/json:
              schema:
                type: object
                properties:
                  mensaje:
                    type: string
                  kfinca:
                    type: string
        '400':
          description: Faltan datos requeridos

  /api/finca:
    put:
      tags: [Fincas]
      summary: Modificar una finca
      security:
        - bearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/FincaUpdate'
      responses:
        '200':
          description: Finca modificada exitosamente
        '400':
          description: Faltan datos requeridos

  /api/finca/{kfinca}:
    delete:
      tags: [Fincas]
      summary: Eliminar una finca
      security:
        - bearerAuth: []
      parameters:
        - name: kfinca
          in: path
          required: true
          schema:
            type: string
      responses:
        '200':
          description: Finca eliminada exitosamente
        '404':
          description: Finca no encontrada

  /api/fincas:
    get:
      tags: [Fincas]
      summary: Listar todas las fincas del agricultor
      security:
        - bearerAuth: []
      responses:
        '200':
          description: Lista de fincas
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/Finca'

components:
  schemas:
    Gasto:
      type: object
      properties:
        kfincagasto:
          type: integer
        kagricultor:
          type: string
        importe_flt:
          type: number
        concepto_str:
          type: string
        campo4:
          type: string
        fecha_dtm:
          type: string
          format: date-time

    GastoInput:
      type: object
      properties:
        importe:
          type: number
        concepto:
          type: string
        campo4:
          type: string
      required: [importe, concepto, campo4]

    AlbaranCabeceraInput:
      type: object
      properties:
        kalmacen:
          type: string
        ktipoprecio:
          type: string
        kcomentario:
          type: string
        kfecha:
          type: string
          format: date

    AlbaranDetalleInput:
      type: object
      properties:
        kalbaran:
          type: string
        kg_float:
          type: number
        kproductos:
          type: string
        numeropallets_int:
          type: integer
        numerocajas_int:
          type: integer
        precio_flt:
          type: number
        comentario_str:
          type: string
      required: [kalbaran, kg_float, kproductos]

    AlbaranDetalle:
      type: object
      properties:
        kalbarandetalle:
          type: integer
        kalbaran:
          type: string
        linea_int:
          type: integer
        kg_float:
          type: number
        numeropallets_int:
          type: integer
        numerocajas_int:
          type: integer
        precio_flt:
          type: number
        kproductos:
          type: string
        comentario_str:
          type: string

    Finca:
      type: object
      properties:
        kfinca:
          type: string
        kfincapadre:
          type: string
        nombre_str:
          type: string
        descripcion_str:
          type: string
        kagricultor:
          type: string
        Ubicacion_str:
          type: string
        aream2_float:
          type: number
        campo1_str:
          type: string
        campo2_str:
          type: string
        fecha:
          type: string
          format: date-time

    FincaInput:
      type: object
      properties:
        nombre_str:
          type: string
        descripcion_str:
          type: string
        kfincapadre:
          type: string
        Ubicacion_str:
          type: string
        aream2_float:
          type: number
        campo1_str:
          type: string
        campo2_str:
          type: string
      required: [nombre_str]

    FincaUpdate:
      type: object
      properties:
        kfinca:
          type: string
        kfincapadre:
          type: string
        nombre_str:
          type: string
        descripcion_str:
          type: string
        Ubicacion_str:
          type: string
        aream2_float:
          type: number
        campo1_str:
          type: string
        campo2_str:
          type: string
      required: [kfinca]

  securitySchemes:
    bearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
