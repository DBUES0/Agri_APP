openapi: 3.0.0
info:
  title: API Bueso
  version: 1.0.0
paths:
  /api/gastos/{id}:
    get:
      summary: Obtener gastos de un agricultor
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      responses:
        '200':
          description: Lista de gastos
          content:
            application/json:
              schema:
                type: array
                items:
                  type: object
  /api/gastos:
    post:
      summary: Insertar nuevo gasto
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                kagricultor:
                  type: string
                importe:
                  type: number
                concepto:
                  type: string
                campo4:
                  type: string
      responses:
        '200':
          description: Gasto insertado
  /api/archivo:
    post:
      summary: Subir archivo
      requestBody:
        required: true
        content:
          multipart/form-data:
            schema:
              type: object
              properties:
                archivo:
                  type: string
                  format: binary
                kuuid:
                  type: string
                tipo:
                  type: string
      responses:
        '200':
          description: Archivo subido correctamente

  /api/gastos/descargararchivonas/{id}:
    get:
      summary: Descargar un archivo desde el servidor por ID
      description: Descarga un archivo del servidor cuya ruta completa está almacenada en el campo 'rutacompleta_str' de la tabla 'tblArchivos' para un ID dado.
      parameters:
        - in: path
          name: id
          required: true
          description: ID del archivo en la base de datos (campo karchivos).
          schema:
            type: string
            format: uuid
      responses:
        '200':
          description: Archivo descargado exitosamente.
          content:
            application/octet-stream:
              schema:
                type: string
                format: binary
              # No se puede definir un nombre de archivo estático aquí, ya que depende de la BBDD.
              # El nombre de archivo se enviará en la cabecera Content-Disposition.
          headers:
            Content-Type:
              schema:
                type: string
              description: Tipo MIME del archivo.
            Content-Disposition:
              schema:
                type: string
              description: Indica que la respuesta es un archivo adjunto y sugiere un nombre de archivo.
            Content-Length:
              schema:
                type: integer
                format: int64
              description: Tamaño del archivo en bytes.
        '404':
          description: Archivo no encontrado en la base de datos o la ruta del archivo no es válida.
          content:
            application/json:
              schema:
                type: object
                properties:
                  error:
                    type: string
                    example: "Archivo no encontrado."
        '500':
          description: Error interno del servidor.
          content:
            application/json:
              schema:
                type: object
                properties:
                  error:
                    type: string
                    example: "Error al procesar la solicitud: [Mensaje de error]"


  /api/gastos/descargararchivo/{id}:
    get:
      summary: Descargar archivo por ID
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      responses:
        '200':
          description: Archivo descargado
          content:
            application/octet-stream:
              schema:
                type: string
                format: binary
        '404':
          description: Archivo no encontrado
          content:
            application/json:
              schema:
                type: object
                properties:
                  error:
                    type: string
        '500':
          description: Error del servidor
          content:
            application/json:
              schema:
                type: object
                properties:
                  error:
                    type: string
