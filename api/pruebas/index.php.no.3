<?php
require 'vendor/autoload.php';

use Psr\Http\Message\ResponseInterface as Response;
use Psr\Http\Message\ServerRequestInterface as Request;
use Slim\Factory\AppFactory;
use Slim\Psr7\UploadedFile;

$app = AppFactory::create();

// Configuración de la base de datos
$servername = "192.168.1.226";
$username = "agricultura";
$password = "Finca2025";
$dbname = "agri";

// Ruta para obtener los gastos de un agricultor
$app->get('/api/gastos/{id}', function (Request $request, Response $response, array $args) use ($servername, $username, $password, $dbname) {
    $id = $args['id'];

    $conn = new mysqli($servername, $username, $password, $dbname);
    if ($conn->connect_error) {
        $response->getBody()->write(json_encode(["error" => "Conexión fallida: " . $conn->connect_error]));
        return $response->withStatus(500)->withHeader('Content-Type', 'application/json');
    }

    $stmt = $conn->prepare("SELECT * FROM tblFincaGastos WHERE kagricultor = ?");
    $stmt->bind_param("s", $id);
    $stmt->execute();
    $result = $stmt->get_result();

    $gastos = $result->fetch_all(MYSQLI_ASSOC);

    $stmt->close();
    $conn->close();

    $response->getBody()->write(json_encode($gastos));
    return $response->withHeader('Content-Type', 'application/json');
});

// Ruta para insertar un nuevo gasto
$app->post('/api/gastos', function (Request $request, Response $response) use ($servername, $username, $password, $dbname) {
    $data = json_decode($request->getBody()->getContents(), true);
    error_log("Datos recibidos: " . json_encode($data));

    if (!isset($data['kagricultor'], $data['importe'], $data['concepto'], $data['campo4'])) {
        $response->getBody()->write(json_encode(["error" => "Faltan datos."]));
        return $response->withStatus(400)->withHeader('Content-Type', 'application/json');
    }

    $kagricultor = $data['kagricultor'];
    $importe = $data['importe'];
    $concepto = $data['concepto'];
    $campo4 = $data['campo4'];

    $conn = new mysqli($servername, $username, $password, $dbname);
    if ($conn->connect_error) {
        $response->getBody()->write(json_encode(["error" => "Conexión fallida: " . $conn->connect_error]));
        return $response->withStatus(500)->withHeader('Content-Type', 'application/json');
    }

    $stmt = $conn->prepare("INSERT INTO tblFincaGastos (kagricultor, importe_flt, concepto_str, campo4) VALUES (?, ?, ?, ?)");
    $stmt->bind_param("sdss", $kagricultor, $importe, $concepto, $campo4);

    if ($stmt->execute()) {
        $response->getBody()->write(json_encode(["mensaje" => "Nuevo gasto insertado correctamente"]));
    } else {
        $response->getBody()->write(json_encode(["error" => "Error: " . $stmt->error]));
        $response = $response->withStatus(500);
    }

    $stmt->close();
    $conn->close();

    return $response->withHeader('Content-Type', 'application/json');
});

// Ruta para insertar un nuevo archivo a un gasto
$app->post('/api/gastos/archivo', function (Request $request, Response $response) use ($servername, $username, $password, $dbname) {
    $parsedBody = $request->getParsedBody();
    $kfincagastos = $parsedBody['kfincagastos'] ?? null;
    $uploadedFiles = $request->getUploadedFiles();

    if (!$kfincagastos || !isset($uploadedFiles['archivo'])) {
        $response->getBody()->write(json_encode(["error" => "Faltan datos o archivo no enviado."]));
        return $response->withStatus(400)->withHeader('Content-Type', 'application/json');
    }

    $file = $uploadedFiles['archivo'];

    if ($file->getError() !== UPLOAD_ERR_OK) {
        $response->getBody()->write(json_encode(["error" => "Error al subir el archivo."]));
        return $response->withStatus(500)->withHeader('Content-Type', 'application/json');
    }

    $filename = $file->getClientFilename();
    $format = strtoupper(pathinfo($filename, PATHINFO_EXTENSION));
    $sizeMB = round($file->getSize() / 1048576, 2);

    // Nueva forma de leer archivo usando Slim\Psr7
    $fileContent = $file->getStream()->getContents();

    $conn = new mysqli($servername, $username, $password, $dbname);
    if ($conn->connect_error) {
        $response->getBody()->write(json_encode(["error" => "Conexión fallida: " . $conn->connect_error]));
        return $response->withStatus(500)->withHeader('Content-Type', 'application/json');
    }

    $stmt = $conn->prepare("INSERT INTO tblFincaGastosArchivos (kfincagastos, archivo_bin, formato_str, sizemb_flt) VALUES (?, ?, ?, ?)");
    $stmt->bind_param("bsss", $kfincagastos, $fileContent, $format, $sizeMB);

    if ($stmt->execute()) {
        $response->getBody()->write(json_encode(["mensaje" => "Archivo subido correctamente"]));
    } else {
        $response->getBody()->write(json_encode(["error" => "Error: " . $stmt->error]));
        $response = $response->withStatus(500);
    }

    $stmt->close();
    $conn->close();

    return $response->withHeader('Content-Type', 'application/json');
});

$app->run();
