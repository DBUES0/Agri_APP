// Ruta para obtener los gastos de un agricultor
$app->get('/api/gastos/{id}', function (Request $request, Response $response, array $args) use ($servername, $username, $password, $dbname) {
    $id = $args['id'];
    
    $conn = new mysqli($servername, $username, $password, $dbname);
    if ($conn->connect_error) {
        $response->getBody()->write(json_encode(["error" => "Conexión fallida: " . $conn->connect_error]));
        return $response->withStatus(500)->withHeader('Content-Type', 'application/json');
    }

    // Uso de sentencia preparada para evitar inyección SQL
    $stmt = $conn->prepare("SELECT * FROM tblFincaGastos WHERE kagricultor = ?");
    $stmt->bind_param("s", $id);
    $stmt->execute();
    $result = $stmt->get_result();

    $gastos = $result->fetch_all(MYSQLI_ASSOC);
    
    $stmt->close();
    $conn->close();

    $response->getBody()->write(json_encode($gastos));
    return $response->withHeader('Content-Type', 'application/json');
});

// Ruta para insertar un nuevo gasto
$app->post('/api/gastos', function (Request $request, Response $response) use ($servername, $username, $password, $dbname) {
    $data = json_decode($request->getBody()->getContents(), true);
    error_log("Datos recibidos: " . json_encode($data));

    if (!isset($data['kagricultor'], $data['importe'], $data['concepto'], $data['campo4'])) {
        $response->getBody()->write(json_encode(["error" => "Faltan datos."]));
        return $response->withStatus(400)->withHeader('Content-Type', 'application/json');
    }

    $kagricultor = $data['kagricultor'];
    $importe = $data['importe'];
    $concepto = $data['concepto'];
    $campo4 = $data['campo4'];

    $conn = new mysqli($servername, $username, $password, $dbname);
    if ($conn->connect_error) {
        $response->getBody()->write(json_encode(["error" => "Conexión fallida: " . $conn->connect_error]));
        return $response->withStatus(500)->withHeader('Content-Type', 'application/json');
    }

    // Uso de sentencia preparada para mayor seguridad
    $stmt = $conn->prepare("INSERT INTO tblFincaGastos (kagricultor, importe_flt, concepto_str, campo4) VALUES (?, ?, ?, ?)");
    $stmt->bind_param("sdss", $kagricultor, $importe, $concepto, $campo4);

    if ($stmt->execute()) {
        $response->getBody()->write(json_encode(["mensaje" => "Nuevo gasto insertado correctamente"]));
    } else {
        $response->getBody()->write(json_encode(["error" => "Error: " . $stmt->error]));
        $response = $response->withStatus(500);
    }

    $stmt->close();
    $conn->close();

    return $response->withHeader('Content-Type', 'application/json');
});

// Ruta para insertar un nuevo archivo a un kgastodado
$app->post('/api/gastos/archivo', function (Request $request, Response $response) use ($servername, $username, $password, $dbname) {
    $parsedBody = $request->getParsedBody();
    $kfincagastos = trim($parsedBody['kfincagastos'] ?? '');
    $uploadedFiles = $request->getUploadedFiles();

    if (!$kfincagastos || !isset($uploadedFiles['archivo'])) {
        $response->getBody()->write(json_encode(["error" => "Faltan datos o archivo no enviado."]));
        return $response->withStatus(400)->withHeader('Content-Type', 'application/json');
    }

    $file = $uploadedFiles['archivo'];

    if ($file->getError() !== UPLOAD_ERR_OK) {
        $response->getBody()->write(json_encode(["error" => "Error al subir el archivo."]));
        return $response->withStatus(500)->withHeader('Content-Type', 'application/json');
    }

    // Obtener datos del archivo
    $filename = $file->getClientFilename();
    $format = strtoupper(pathinfo($filename, PATHINFO_EXTENSION)); // Extensión en mayúsculas
    $sizeMB = round($file->getSize() / 1048576, 2); // Convertir bytes a MB

    // Leer el archivo como binario
    $fileContent = file_get_contents($file->getStream()->getMetadata('uri'));

    $conn = new mysqli($servername, $username, $password, $dbname);
    if ($conn->connect_error) {
        $response->getBody()->write(json_encode(["error" => "Conexión fallida: " . $conn->connect_error]));
        return $response->withStatus(500)->withHeader('Content-Type', 'application/json');
    }

    // Insertar el archivo en la base de datos
    $stmt = $conn->prepare("INSERT INTO tblFincaGastosArchivos (kfincagastos, archivo_bin, formato_str, sizemb_flt, nombrearchivo_str) VALUES (?, ?, ?, ?, ?)");
    $stmt->bind_param("sbsss", $kfincagastos, $null, $format, $sizeMB, $filename); // 'b' para blob, $null como marcador
    // Enviar el contenido binario manualmente
    $stmt->send_long_data(1, $fileContent); // El índice 1 corresponde al segundo parámetro (?, ?, ..., ?)

    if ($stmt->execute()) {
        // Obtener el ID del archivo insertado (esto puede no funcionar bien con UUID)
        $last_id = $conn->insert_id;
        
        // Alternativa mejor: obtener el UUID generado por el trigger
        $getUuidStmt = $conn->prepare("SELECT kfincagastosarchivos FROM tblFincaGastosArchivos WHERE kfincagastos = ? ORDER BY fecha_dtm DESC LIMIT 1");
        $getUuidStmt->bind_param("s", $kfincagastos);
        $getUuidStmt->execute();
        $getUuidStmt->bind_result($insertedUuid);
        $getUuidStmt->fetch();
        $getUuidStmt->close();
        
        // Verificar el archivo insertado usando el UUID
        $verifyStmt = $conn->prepare("SELECT archivo_bin FROM tblFincaGastosArchivos WHERE kfincagastosarchivos = ?");
        $verifyStmt->bind_param("s", $insertedUuid);
        $verifyStmt->execute();
        $verifyStmt->store_result();
        
        if ($verifyStmt->num_rows === 0) {
            $verifyStmt->close();
            $conn->close();
            $response->getBody()->write(json_encode(["error" => "Error: No se pudo verificar el archivo subido"]));
            return $response->withStatus(500)->withHeader('Content-Type', 'application/json');
        }
        
        $verifyStmt->bind_result($verifyContent);
        $verifyStmt->fetch();
        $verifyStmt->close();
        if (strlen($verifyContent) !== $file->getSize()) {
            // Eliminar el registro si hay discrepancia
            $conn->query("DELETE FROM tblFincaGastosArchivos WHERE kfincagastosarchivos = '$insertedUuid'");
            $conn->close();
            $response->getBody()->write(json_encode(["error" => "Error: El archivo no se almacenó correctamente"]));
            return $response->withStatus(500)->withHeader('Content-Type', 'application/json');
        }
        $conn->close();
        $response->getBody()->write(json_encode([
            "mensaje" => "Archivo subido correctamente",
            "uuid" => $insertedUuid
        ]));
    } else {
        $response->getBody()->write(json_encode(["error" => "Error: " . $stmt->error]));
        $response = $response->withStatus(500);
        $stmt->close();
        $conn->close();
    }
    return $response->withHeader('Content-Type', 'application/json');
});

// Ruta para descargar un archivo por su clave primaria
$app->get('/api/gastos/descargararchivo/{id}', function (Request $request, Response $response, array $args) use ($servername, $username, $password, $dbname) {
    $id = $args['id'];

    $conn = new mysqli($servername, $username, $password, $dbname);
    if ($conn->connect_error) {
        $response->getBody()->write(json_encode(["error" => "Conexión fallida: " . $conn->connect_error]));
        return $response->withStatus(500)->withHeader('Content-Type', 'application/json');
    }

    // Obtener más información del archivo
    $stmt = $conn->prepare("SELECT archivo_bin, formato_str, nombrearchivo_str FROM tblFincaGastosArchivos WHERE kfincagastosarchivos = ?");
    $stmt->bind_param("s", $id);
    $stmt->execute();
    $stmt->store_result();

    if ($stmt->num_rows === 0) {
        $stmt->close();
        $conn->close();
        $response->getBody()->write(json_encode(["error" => "Archivo no encontrado."]));
        return $response->withStatus(404)->withHeader('Content-Type', 'application/json');
    }

    $stmt->bind_result($archivoBin, $formato, $nombreArchivo);
    $stmt->fetch();
    $stmt->close();
    $conn->close();

    // Determinar el nombre del archivo a descargar
    $downloadName = $nombreArchivo ?: "archivo_$id.$formato";

    // Crear una nueva respuesta con el contenido binario
    $response = $response
        ->withHeader('Content-Description', 'File Transfer')
        ->withHeader('Content-Type', 'application/octet-stream')
        ->withHeader('Content-Disposition', 'attachment; filename="' . $downloadName . '"')
