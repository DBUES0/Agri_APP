<?php
require 'vendor/autoload.php';

use Psr\Http\Message\ResponseInterface as Response;
use Psr\Http\Message\ServerRequestInterface as Request;
use Slim\Factory\AppFactory;

$app = AppFactory::create();

// Configuración de la base de datos
$servername = "192.168.1.226";
$username = "agricultura";
$password = "Finca2025";
$dbname = "agri";

// Función para conexión a base de datos
function conectarDB($servername, $username, $password, $dbname)
{
    $conn = new mysqli($servername, $username, $password, $dbname);
    if ($conn->connect_error) {
        throw new Exception("Conexión fallida: " . $conn->connect_error);
    }
    return $conn;
}

// Función común para subir archivo
function subirArchivo(Request $request, Response $response, $servername, $username, $password, $dbname): Response
{
    $parsedBody = $request->getParsedBody();
    $kfincagastos = trim($parsedBody['kfincagastos'] ?? '');
    $uploadedFiles = $request->getUploadedFiles();

    if (!$kfincagastos || !isset($uploadedFiles['archivo'])) {
        return $response->withStatus(400)->withHeader('Content-Type', 'application/json')
            ->write(json_encode(["error" => "Faltan datos o archivo no enviado."]));
    }

    $file = $uploadedFiles['archivo'];
    if ($file->getError() !== UPLOAD_ERR_OK) {
        return $response->withStatus(500)->withHeader('Content-Type', 'application/json')
            ->write(json_encode(["error" => "Error al subir el archivo."]));
    }

    $filename = $file->getClientFilename();
    $format = strtoupper(pathinfo($filename, PATHINFO_EXTENSION));
    $sizeMB = round($file->getSize() / 1048576, 2);

    $stream = $file->getStream();
    $stream->rewind();
    $fileContent = $stream->getContents();

    try {
        $conn = conectarDB($servername, $username, $password, $dbname);
        $stmt = $conn->prepare("INSERT INTO tblFincaGastosArchivos (kfincagastos, archivo_bin, formato_str, sizemb_flt, nombrearchivo_str) VALUES (?, ?, ?, ?, ?)");
        $null = null;
        $stmt->bind_param("sbsss", $kfincagastos, $null, $format, $sizeMB, $filename);
        $stmt->send_long_data(1, $fileContent);
        $stmt->execute();
        $stmt->close();

        // Obtener UUID
        $uuidStmt = $conn->prepare("SELECT kfincagastosarchivos FROM tblFincaGastosArchivos WHERE kfincagastos = ? ORDER BY fecha_dtm DESC LIMIT 1");
        $uuidStmt->bind_param("s", $kfincagastos);
        $uuidStmt->execute();
        $uuidStmt->bind_result($uuid);
        $uuidStmt->fetch();
        $uuidStmt->close();

        // Verificar tamaño
        $verifyStmt = $conn->prepare("SELECT OCTET_LENGTH(archivo_bin) FROM tblFincaGastosArchivos WHERE kfincagastosarchivos = ?");
        $verifyStmt->bind_param("s", $uuid);
        $verifyStmt->execute();
        $verifyStmt->bind_result($storedLength);
        $verifyStmt->fetch();
        $verifyStmt->close();

        if ($storedLength !== $file->getSize()) {
            $conn->query("DELETE FROM tblFincaGastosArchivos WHERE kfincagastosarchivos = '$uuid'");
            $conn->close();
            return $response->withStatus(500)->withHeader('Content-Type', 'application/json')
                ->write(json_encode(["error" => "Error: El archivo no se almacenó correctamente"]));
        }

        $conn->close();
        return $response->withHeader('Content-Type', 'application/json')
            ->write(json_encode(["mensaje" => "Archivo subido correctamente", "uuid" => $uuid]));

    } catch (Exception $e) {
        return $response->withStatus(500)->withHeader('Content-Type', 'application/json')
            ->write(json_encode(["error" => $e->getMessage()]));
    }
}

// Obtener gastos de un agricultor
$app->get('/api/gastos/{id}', function (Request $request, Response $response, array $args) use ($servername, $username, $password, $dbname) {
    try {
        $conn = conectarDB($servername, $username, $password, $dbname);
        $stmt = $conn->prepare("SELECT * FROM tblFincaGastos WHERE kagricultor = ?");
        $stmt->bind_param("s", $args['id']);
        $stmt->execute();
        $result = $stmt->get_result();
        $gastos = $result->fetch_all(MYSQLI_ASSOC);
        $stmt->close();
        $conn->close();
        $response->getBody()->write(json_encode($gastos));
        return $response->withHeader('Content-Type', 'application/json');
    } catch (Exception $e) {
        $response->getBody()->write(json_encode(["error" => $e->getMessage()]));
        return $response->withStatus(500)->withHeader('Content-Type', 'application/json');
    }
});

// Insertar un nuevo gasto
$app->post('/api/gastos', function (Request $request, Response $response) use ($servername, $username, $password, $dbname) {
    $data = json_decode($request->getBody()->getContents(), true);

    if (!isset($data['kagricultor'], $data['importe'], $data['concepto'], $data['campo4'])) {
        return $response->withStatus(400)->withHeader('Content-Type', 'application/json')
            ->write(json_encode(["error" => "Faltan datos."]));
    }

    try {
        $conn = conectarDB($servername, $username, $password, $dbname);
        $stmt = $conn->prepare("INSERT INTO tblFincaGastos (kagricultor, importe_flt, concepto_str, campo4) VALUES (?, ?, ?, ?)");
        $stmt->bind_param("sdss", $data['kagricultor'], $data['importe'], $data['concepto'], $data['campo4']);
        $stmt->execute();
        $stmt->close();
        $conn->close();
        $response->getBody()->write(json_encode(["mensaje" => "Nuevo gasto insertado correctamente"]));
    } catch (Exception $e) {
        $response->getBody()->write(json_encode(["error" => $e->getMessage()]));
        return $response->withStatus(500)->withHeader('Content-Type', 'application/json');
    }

    return $response->withHeader('Content-Type', 'application/json');
});

// Subir archivo (dos rutas válidas)
$app->post('/api/gastos/archivo', function (Request $request, Response $response) use ($servername, $username, $password, $dbname) {
    return subirArchivo($request, $response, $servername, $username, $password, $dbname);
});
$app->post('/api/gastos/archivo1', function (Request $request, Response $response) use ($servername, $username, $password, $dbname) {
    return subirArchivo($request, $response, $servername, $username, $password, $dbname);
});

// Descargar archivo por ID
$app->get('/api/gastos/descargararchivo/{id}', function (Request $request, Response $response, array $args) use ($servername, $username, $password, $dbname) {
    try {
        $conn = conectarDB($servername, $username, $password, $dbname);
        $stmt = $conn->prepare("SELECT archivo_bin, formato_str, nombrearchivo_str FROM tblFincaGastosArchivos WHERE kfincagastosarchivos = ?");
        $stmt->bind_param("s", $args['id']);
        $stmt->execute();
        $stmt->store_result();

        if ($stmt->num_rows === 0) {
            $stmt->close();
            $conn->close();
            return $response->withStatus(404)->withHeader('Content-Type', 'application/json')
                ->write(json_encode(["error" => "Archivo no encontrado."]));
        }

        $stmt->bind_result($archivoBin, $formato, $nombreArchivo);
        $stmt->fetch();
        $stmt->close();
        $conn->close();

        $downloadName = $nombreArchivo ?: "archivo_{$args['id']}.$formato";
        return $response
            ->withHeader('Content-Type', 'application/octet-stream')
            ->withHeader('Content-Disposition', 'attachment; filename="' . $downloadName . '"')
            ->withHeader('Content-Length', strlen($archivoBin))
            ->write($archivoBin);

    } catch (Exception $e) {
        return $response->withStatus(500)->withHeader('Content-Type', 'application/json')
            ->write(json_encode(["error" => $e->getMessage()]));
    }
});

$app->run();
