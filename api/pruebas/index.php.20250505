// Función para conexión a base de datos
function conectarDB($servername, $username, $password, $dbname)
{
    $conn = new mysqli($servername, $username, $password, $dbname);
    if ($conn->connect_error) {
        throw new Exception("Conexión fallida: " . $conn->connect_error);
    }
    return $conn;
}

// Función para enviar un retorno por consola
function jsonResponse(Response $response, $data, int $status = 200): Response {
    $json = json_encode($data);
    if ($json === false) {
        // Fallback en caso de error al codificar JSON
        $json = json_encode(["error" => "Error al codificar los datos"]);
        $status = 500;
    }
    $response->getBody()->write($json);
    return $response->withStatus($status)->withHeader('Content-Type', 'application/json');
}
//    $response->getBody()->write(json_encode($data));
