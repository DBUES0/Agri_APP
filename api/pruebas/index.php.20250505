    $query = "SELECT t.* FROM tbltrabajadores t
              JOIN tbltrabajadoraltas a ON t.ktrabajador = a.ktrabajador
              WHERE t.kagricultor = ? AND t.eliminado_bit = b'0' AND (a.fechafin_dtm IS NULL OR a.fechafin_dtm > NOW())";
