// Insertar una nueva cabecera de albaran
$app->post('/api/albarancabecera[/]', function (Request $request, Response $response) use ($servername, $username, $password, $dbname) {
    $data = json_decode($request->getBody()->getContents(), true);

    if (!isset($data['kagricultor'])) {
        return jsonResponse($response, ["error" => "Faltan datos."], 400);  
    }
    
    $kalmacen = $data['kalmacen'] ?? null;  
    $ktipoprecio = $data['ktipoprecio'] ?? null;  
    $kcomentario = $data['kcomentario'] ?? null;  
    $kfecha = $data['kfecha'] ?? date('Y-m-d'); // Valor por defecto si no se envía

    try {
        $conn = conectarDB($servername, $username, $password, $dbname);
        
        // CORRECCIÓN PRINCIPAL: Paréntesis cerrado correctamente
        $stmt = $conn->prepare("INSERT INTO tblAlbaranesCabecera(kagricultor, fecha_dtm, kalmacen, ktipodeprecio, comentario_str) VALUES (?, ?, ?, ?, ?)");
        
        $stmt->bind_param("sssss", $data['kagricultor'], $kfecha, $kalmacen, $ktipoprecio, $kcomentario);
        
        if (!$stmt->execute()) {
            throw new Exception("Error al ejecutar la consulta: " . $stmt->error);
        }
        
        $nuevoId = $conn->insert_id;
        $stmt->close();
		
		$uuidStmt = $conn->prepare("SELECT kalbaran FROM tblAlbaranesCabecera WHERE kagricultor = ? ORDER BY fecha_dtm DESC LIMIT 1");
        $uuidStmt->bind_param("s", $data['kagricultor']);
        $uuidStmt->execute();
        $uuidStmt->bind_result($kalbaran);
        $uuidStmt->fetch();
        $uuidStmt->close();
		
        $conn->close();
        
        return jsonResponse($response, [
            "mensaje" => "Cabecera de albarán creada correctamente",
            "kalbaran" => $kalbaran,
			"nuevoid" => $nuevoId
        ]);
        
    } catch (Exception $e) {
        error_log("Error en albarancabecera: " . $e->getMessage());
        return jsonResponse($response, [
            "error" => "Error al procesar el albarán",
            "detalle" => $e->getMessage()
        ], 500);
    }
});

// Insertar un nuevo detalle de albarán
$app->post('/api/albarandetalles[/]', function (Request $request, Response $response) use ($servername, $username, $password, $dbname) {
    $data = json_decode($request->getBody()->getContents(), true);

    // Validación de campos obligatorios
    if (!isset($data['kalbaran'], $data['kg_float'], $data['kproductos'])) {
        return jsonResponse($response, ["error" => "Faltan campos obligatorios (kalbaran, kg_float, kproductos)"], 400);
    }

    try {
        $conn = conectarDB($servername, $username, $password, $dbname);
        
        // El trigger se encargará del autonumérico de línea
        $stmt = $conn->prepare("INSERT INTO tblalbaranesDetalles 
                              (kalbaran, kg_float, numeropallets_int, numerocajas_int, precio_flt, kproductos, comentario_str) 
                              VALUES (?, ?, ?, ?, ?, ?, ?)");
        
        // Asignamos valores a variables primero
        $numeropallets = $data['numeropallets_int'] ?? null;
        $numerocajas = $data['numerocajas_int'] ?? null;
        $precio = $data['precio_flt'] ?? null;
        $comentario = $data['comentario_str'] ?? null;
        
        $stmt->bind_param("sddddss", 
            $data['kalbaran'],
            $data['kg_float'],
            $numeropallets,
            $numerocajas,
            $precio,
            $data['kproductos'],
            $comentario
        );

        if (!$stmt->execute()) {
            throw new Exception("Error al insertar detalle: " . $stmt->error);
        }

        $nuevoId = $conn->insert_id;
        $stmt->close();
        
        // Obtenemos el detalle completo recién creado (incluyendo la línea generada por el trigger)
        $stmt = $conn->prepare("SELECT * FROM tblalbaranesDetalles WHERE kalbarandetalle = ?");
        $stmt->bind_param("s", $nuevoId);
        $stmt->execute();
        $result = $stmt->get_result();
        $detalle = $result->fetch_assoc();
        
        $stmt->close();
        $conn->close();

        return jsonResponse($response, [
            "mensaje" => "Detalle de albarán creado correctamente",
            "detalle" => $detalle
        ], 201);

    } catch (Exception $e) {
        if (isset($conn) && $conn) {
            $conn->close();
        }
        return jsonResponse($response, ["error" => $e->getMessage()], 500);
    }
});

// Obtener detalles de un albarán
$app->get('/api/albarandetalles/{kalbaran}', function (Request $request, Response $response, array $args) use ($servername, $username, $password, $dbname) {
    try {
        $conn = conectarDB($servername, $username, $password, $dbname);
        $stmt = $conn->prepare("SELECT * FROM tblalbaranesDetalles WHERE kalbaran = ? ORDER BY linea_int");
        $stmt->bind_param("s", $args['kalbaran']);
        $stmt->execute();
        $result = $stmt->get_result();
        $detalles = $result->fetch_all(MYSQLI_ASSOC);
        
        if (empty($detalles)) {
            return jsonResponse($response, ["error" => "No se encontraron detalles para el albarán especificado"], 404);
        }
        
        $stmt->close();
        $conn->close();
        
        return jsonResponse($response, $detalles);
        
    } catch (Exception $e) {
        if (isset($conn) && $conn) {
            $conn->close();
        }
        return jsonResponse($response, ["error" => $e->getMessage()], 500);
    }
});

